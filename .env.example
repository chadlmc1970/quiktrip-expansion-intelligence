# QuikTrip Expansion Intelligence - Environment Variables

# Neon Database (Free Tier)
# Create at: https://neon.tech
# Format: postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.neon.tech/neondb?sslmode=require

# Anthropic API Key (for AI site scoring)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# AI Model
AI_MODEL=claude-opus-4-6

# Frontend API URL (set after backend deploys)
NEXT_PUBLIC_API_URL=https://quiktrip-expansion-api.onrender.com
